<?php

/**
 * Implements hook_preprocess_HOOK() for fieldset.
 */
function unity_intranet_content_manager_preprocess_fieldset(&$variables) {
  $element = &$variables['element'];
  if ($element['#id'] == 'group-publications') {
    $variables['legend_span']['attributes']['class'][] = 'js-form-required form-required';
  }
}
